{
  "name": "Purchase",
  "type": "object",
  "properties": {
    "shop_item_id": {
      "type": "string",
      "description": "ID of the purchased item"
    },
    "item_name": {
      "type": "string",
      "description": "Name of the item purchased"
    },
    "price": {
      "type": "number",
      "description": "Price paid in coins"
    }
  },
  "required": [
    "shop_item_id",
    "item_name",
    "price"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "created_by": "{{user.email}}"
    },
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}